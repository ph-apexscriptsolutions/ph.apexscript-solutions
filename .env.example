# Supabase public client values for frontend usage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase admin values for server-side usage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PAYSLIP_BUCKET=payslips

# Optional local DB connection string for migrations
DATABASE_URL=postgres://postgres:your-password@db.host.supabase.co:5432/postgres
# or
# SUPABASE_DB_CONNECTION_STRING=postgres://postgres:your-password@db.host.supabase.co:5432/postgres

# Optional email settings if used by the project
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
