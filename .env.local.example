# Copy this file to `.env.local` and fill in the DATABASE_URL for your Postgres/Supabase DB.
# Do NOT commit your real credentials.
# Example DATABASE_URL formats:
# Postgres: postgres://user:password@host:5432/postgres
# Supabase: postgres://postgres:password@db.<project>.supabase.co:5432/postgres

# Set either DATABASE_URL or SUPABASE_DB_CONNECTION_STRING
DATABASE_URL=

# Supabase runtime settings for server routes
# SUPABASE_URL=https://<your-project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PAYSLIP_BUCKET=payslips

# Optional: if you use SMTP in the project (EMAIL_USER/EMAIL_PASS), add them here as well
# EMAIL_USER=
# EMAIL_PASS=
